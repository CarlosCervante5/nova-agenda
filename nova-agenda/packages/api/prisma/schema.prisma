generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  domain        String?   @unique
  email         String?
  phone         String?
  address       String?
  logo          String?
  primaryColor  String    @default("#5950b6")
  isActive      Boolean   @default(true)
  plan          String    @default("FREE")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  users         User[]
  services      Service[]
  bookings      Booking[]
  workingHours  WorkingHours[]
  whatsappConfig WhatsAppConfig?
  whatsappLogs   WhatsAppLog[]

  @@map("clients")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  role          String    @default("CLIENT")
  avatar        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  client        Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId      String?

  @@map("users")
}

model Service {
  id            String    @id @default(cuid())
  name          String
  description   String?
  duration      Int
  price         Float?
  isActive      Boolean   @default(true)
  color         String    @default("#5950b6")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId      String
  bookings      Booking[]

  @@map("services")
}

model Booking {
  id            String    @id @default(cuid())
  customerName  String
  customerEmail String?
  customerPhone String?
  date          DateTime
  startTime     String
  endTime       String
  status        String    @default("PENDING")
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId      String
  service       Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId     String

  @@map("bookings")
}

model WorkingHours {
  id            String    @id @default(cuid())
  dayOfWeek     Int
  openTime      String
  closeTime     String
  isOpen        Boolean   @default(true)

  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId      String

  @@unique([clientId, dayOfWeek])
  @@map("working_hours")
}

model WhatsAppConfig {
  id              String   @id @default(cuid())
  clientId        String   @unique
  phoneNumberId   String
  apiKey          String
  instanceId      String?
  webhookToken    String?
  isOpenAIEnabled Boolean  @default(true)
  aiPersonality   String   @default("Eres un asistente amable y profesional de un negocio de belleza. Tu objetivo es ayudar a los clientes con información y reservar citas.")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("whatsapp_config")
}

model WhatsAppLog {
  id          String   @id @default(cuid())
  clientId    String
  phoneNumber String
  direction   String
  message     String
  intent      String?
  bookingId   String?
  metadata    String?
  createdAt   DateTime @default(now())

  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("whatsapp_logs")
}

model PlatformConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  category    String
  label       String?
  updatedAt   DateTime @updatedAt

  @@map("platform_config")
}
