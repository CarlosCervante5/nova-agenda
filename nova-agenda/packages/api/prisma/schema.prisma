generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  domain        String?   @unique
  email         String?
  phone         String?
  address       String?
  logo          String?
  primaryColor  String    @default("#5950b6")
  tagline       String?
  about         String?
  coverImage    String?
  instagram     String?
  facebook      String?
  whatsappPhone String?
  websiteEnabled Boolean  @default(true)
  isActive      Boolean   @default(true)
  plan          String    @default("FREE")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  users         User[]
  services      Service[]
  bookings      Booking[]
  staffMembers  StaffMember[]
  workingHours  WorkingHours[]
  whatsappConfig WhatsAppConfig?
  whatsappLogs   WhatsAppLog[]
  loyaltyProgram LoyaltyProgram?

  @@map("clients")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  role          String    @default("CLIENT")
  avatar        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  client        Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId      String?

  @@map("users")
}

model Service {
  id            String    @id @default(cuid())
  name          String
  description   String?
  duration      Int
  price         Float?
  isActive      Boolean   @default(true)
  color         String    @default("#5950b6")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId      String
  bookings      Booking[]
  staffServices StaffService[]

  @@map("services")
}

model StaffMember {
  id            String    @id @default(cuid())
  name          String
  email         String?
  phone         String?
  title         String?   // cargo: Estilista, Terapeuta, etc.
  bio           String?
  color         String    @default("#5950b6")
  avatarUrl     String?
  isActive      Boolean   @default(true)
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId      String
  services      StaffService[]
  bookings      Booking[]

  @@map("staff_members")
}

model StaffService {
  id            String      @id @default(cuid())
  staff         StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)
  staffId       String
  service       Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId     String

  @@unique([staffId, serviceId])
  @@map("staff_services")
}

model Booking {
  id            String    @id @default(cuid())
  customerName  String
  customerEmail String?
  customerPhone String?
  date          DateTime
  startTime     String
  endTime       String
  status        String    @default("PENDING")
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId      String
  service       Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId     String
  staff         StaffMember? @relation(fields: [staffId], references: [id], onDelete: SetNull)
  staffId       String?
  loyaltyStamp  LoyaltyStamp?

  @@map("bookings")
}

model WorkingHours {
  id            String    @id @default(cuid())
  dayOfWeek     Int
  openTime      String
  closeTime     String
  isOpen        Boolean   @default(true)

  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId      String

  @@unique([clientId, dayOfWeek])
  @@map("working_hours")
}

model WhatsAppConfig {
  id              String   @id @default(cuid())
  clientId        String   @unique
  phoneNumberId   String
  apiKey          String
  instanceId      String?
  webhookToken    String?
  isOpenAIEnabled Boolean  @default(true)
  aiPersonality   String   @default("Eres un asistente amable y profesional de un negocio de belleza. Tu objetivo es ayudar a los clientes con información y reservar citas.")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("whatsapp_config")
}

model WhatsAppLog {
  id          String   @id @default(cuid())
  clientId    String
  phoneNumber String
  direction   String
  message     String
  intent      String?
  bookingId   String?
  metadata    String?
  createdAt   DateTime @default(now())

  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("whatsapp_logs")
}

model LoyaltyProgram {
  id            String    @id @default(cuid())
  clientId      String    @unique
  name          String
  description   String?
  stampsToReward Int      @default(10)
  isActive      Boolean   @default(false)
  stampIcon     String    @default("local_fire_department")
  stampColor    String    @default("#5950b6")
  backgroundColor String  @default("#ffffff")
  textColor     String    @default("#191c1e")
  enableWhatsApp Boolean  @default(false)
  welcomeMessage String?  @default("¡Bienvenido al programa de fidelidad! Recibirás un sello por cada visita.")
  rewardMessage  String?  @default("¡Felicitaciones! Has completado tu tarjeta y ganado una recompensa.")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  rewards       LoyaltyReward[]
  cards         LoyaltyCard[]

  @@map("loyalty_programs")
}

model LoyaltyReward {
  id            String    @id @default(cuid())
  programId     String
  name          String
  description   String?
  stampsRequired Int
  rewardType    String    @default("SERVICE_DISCOUNT") // SERVICE_DISCOUNT, FREE_SERVICE, PERCENTAGE_DISCOUNT, FIXED_AMOUNT, CUSTOM
  value         Float     // discount amount, percentage, or service ID reference
  serviceId     String?   // for FREE_SERVICE type
  isActive      Boolean   @default(true)
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  program       LoyaltyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@map("loyalty_rewards")
}

model LoyaltyCard {
  id            String    @id @default(cuid())
  programId     String
  customerName  String
  customerEmail String?
  customerPhone String?
  stampsEarned  Int       @default(0)
  stampsRedeemed Int      @default(0)
  lastVisitAt   DateTime?
  completedAt   DateTime?
  isCompleted   Boolean   @default(false)
  metadata      String?   // JSON for extra data
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  program       LoyaltyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  stamps        LoyaltyStamp[]

  @@unique([programId, customerPhone])
  @@unique([programId, customerEmail])
  @@map("loyalty_cards")
}

model LoyaltyStamp {
  id            String    @id @default(cuid())
  cardId        String
  bookingId     String?   @unique
  serviceId     String?
  stampsGiven   Int       @default(1)
  note          String?
  createdAt     DateTime  @default(now())

  card          LoyaltyCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  booking       Booking?  @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@map("loyalty_stamps")
}

model PlatformConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  category    String
  label       String?
  updatedAt   DateTime @updatedAt

  @@map("platform_config")
}
