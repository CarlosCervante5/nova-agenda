# =====================================================
# Nova Agenda — Environment Variables
# =====================================================
# Copia este archivo como .env y configura cada variable.

# ─── Database ─────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nova_agenda?schema=public"

# ─── JWT ──────────────────────────────────────────────
# ¡CAMBIA ESTO en producción! Usa un string largo y aleatorio.
JWT_SECRET="your-super-secret-key-change-in-production"

# ─── API ──────────────────────────────────────────────
API_PORT=3001

# ─── CORS (dominios permitidos, separados por coma) ──
# Producción: https://novaagenda.com,https://app.novaagenda.com,https://novaagenda.com
CORS_ORIGIN="http://localhost:3002,http://localhost:3003,http://localhost:3004"

# ─── API URL (para servicios que necesitan llamar a la API) ─
# Producción: https://api.novaagenda.com
API_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:3001"

# ─── Client Sites (portal de reservas) ────────────────
# Producción: https://novaagenda.com
NEXT_PUBLIC_CLIENT_PORTAL_URL="http://localhost:3004"

# ─── Website (landing) → enlace al panel admin ────────
# Producción: https://app.novaagenda.com
NEXT_PUBLIC_ADMIN_URL="http://localhost:3002"

# ─── Multi-tenant ─────────────────────────────────────
MULTI_TENANT_BASE_DOMAIN="localhost"
# Producción: novaagenda.com (para subdominios tipo cliente.novaagenda.com)

# ─── Evo Cloud WhatsApp API ──────────────────────────
EVO_CLOUD_API_URL="https://api.evo.cloud"
EVO_CLOUD_API_KEY="your-evo-cloud-api-key"
EVO_CLOUD_INSTANCE_ID="your-instance-id"

# ─── OpenAI ──────────────────────────────────────────
OPENAI_API_KEY="your-openai-api-key"

# ─── Stripe (suscripciones) ──────────────────────────
# ¡CAMBIA A live keys para producción!
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID_BASIC="price_..."
STRIPE_PRICE_ID_PRO="price_..."

# =====================================================
# RAILWAY — Variables por servicio
# =====================================================
#
# SERVICIO API (nova-agenda-api):
#   DATABASE_URL=postgresql://...
#   JWT_SECRET=<genera uno seguro>
#   CORS_ORIGIN=https://novaagenda.com,https://app.novaagenda.com
#   STRIPE_SECRET_KEY=sk_live_...
#   STRIPE_WEBHOOK_SECRET=whsec_...
#   EVO_CLOUD_API_URL=https://api.evo.cloud
#   EVO_CLOUD_API_KEY=...
#   EVO_CLOUD_INSTANCE_ID=...
#   OPENAI_API_KEY=...
#
# SERVICIO ADMIN (nova-agenda-admin):
#   API_URL=https://api.novaagenda.com
#   NEXT_PUBLIC_API_URL=https://api.novaagenda.com
#   NEXT_PUBLIC_CLIENT_PORTAL_URL=https://novaagenda.com
#
# SERVICIO WEBSITE (nova-agenda-website):
#   NEXT_PUBLIC_ADMIN_URL=https://app.novaagenda.com
#
# SERVICIO CLIENT-SITES (nova-agenda-client-sites):
#   API_URL=https://api.novaagenda.com
#   NEXT_PUBLIC_API_URL=https://api.novaagenda.com
