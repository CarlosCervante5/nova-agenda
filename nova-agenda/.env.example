# Admin — portal de reservas (client-sites)
NEXT_PUBLIC_CLIENT_PORTAL_URL="http://localhost:3004"

# Website (landing) → enlace al panel admin
NEXT_PUBLIC_ADMIN_URL="http://localhost:3002"

# Website producción (Railway admin)
# NEXT_PUBLIC_ADMIN_URL="https://spirited-determination-production-a075.up.railway.app"

# --- Railway (producción) ---
